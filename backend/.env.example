# ASSist Backend Configuration
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=ASSist
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Security - Generate a strong random key for production!
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_key

# Session Settings
SESSION_MAX_AGE=3600

# CORS - set to your frontend URL
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Frontend redirect URL after OAuth login
FRONTEND_URL=http://localhost:5173

# Trusted hosts (production: add your actual domain)
TRUSTED_HOSTS=["localhost","127.0.0.1","*.local"]

# Google OAuth2
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# AI Backend: "ollama" (local, recommended for privacy), "openai", or "gemini"
AI_BACKEND=ollama

# Ollama (local AI - recommended for privacy/FERPA compliance)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (if using cloud AI - note: data leaves your network)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini (if using cloud AI - note: data leaves your network)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
